{
  "name": "content-slide-renderer",
  "version": "1.0.0",
  "description": "Puppeteer based slide generator for brand-guided card news",
  "main": "scripts/render.js",
  "scripts": {
    "render": "node scripts/render.js",
    "render:raw": "node scripts/render.js",
    "build": "npx @tailwindcss/cli -i src/input.css -o public/style.css",
    "dev": "npx @tailwindcss/cli -i src/input.css -o public/style.css --watch"
  },
  "dependencies": {
    "puppeteer": "^22.0.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.1",
    "postcss": "^8.5.8",
    "postcss-cli": "^11.0.1",
    "tailwindcss": "^4.2.1"
  }
}
