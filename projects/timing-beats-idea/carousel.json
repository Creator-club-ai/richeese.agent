-all}.ed__note{margin-top:auto;padding-top:20px;border-top:1px solid rgba(20,19,17,.16);max-width:820px;font-size:18px;line-height:1.72;letter-spacing:-.012em;color:#5d5751;font-weight:500;word-break:keep-all}"
