:keep-all}.tr__card--accent .tr__card-body{color:rgba(241,237,229,.8)}.tr__note{margin:28px 0 0;font-family:'neue-haas-grotesk-display','Helvetica Neue','Arial',sans-serif;font-size:18px;line-height:1.4;font-weight:300;letter-spacing:.08em;color:#6a635c}"
