    {
      "theme": "light",
      "chrome": "full",
      "footer": "minimal",
      "html": "<div class=\"s6\">\n  <div class=\"s6__top\">\n    <div class=\"s6__tag\">03. PRE-STARTUP</div>\n    <div class=\"s6__title\">예비창업패키지\n<span class=\"s6__muted\">(수정 공고)</span></div>\n  </div>\n\n  <div class=\"s6__date\">03.06 <span class=\"s6__dash\"></span> 03.24</div>\n\n  <div class=\"s6__note\">접수기간 기준. 자격/서류는 원문 확인.</div>\n</div>",
      "css": ".s6{height:100%;display:flex;flex-direction:column;justify-content:center;gap:46px} .s6__tag{font-size:18px;font-weight:900;letter-spacing:.16em;color:var(--color-accent)} .s6__title{white-space:pre-line;font-size:92px;font-weight:900;letter-spacing:-0.05em;line-height:1.08;color:var(--color-text-primary)} .s6__muted{color:var(--color-text-secondary);font-weight:800} .s6__date{display:flex;align-items:center;gap:22px;font-size:108px;font-weight:900;letter-spacing:-0.06em;color:var(--color-text-primary)} .s6__dash{display:inline-block;flex:1;height:10px;background:var(--color-accent);max-width:280px} .s6__note{font-size:32px;font-weight:600;color:var(--color-text-secondary);max-width:920px;line-height:1.55;word-break:keep-all}"
