      "chrome": "full",
      "footer": "minimal",
      "html": "<div class=\"s5\">\n  <div class=\"s5__top\">\n    <div class=\"s5__tag\">02. SCALE-UP</div>\n    <div class=\"s5__title\">창업도약패키지\n<span class=\"s5__muted\">(일반형)</span></div>\n  </div>\n\n  <div class=\"s5__date\">01.23 <span class=\"s5__dash\"></span> 02.13</div>\n\n  <div class=\"s5__note\">유형(일반/특화 등)에 따라 접수기간이 다를 수 있어요.</div>\n</div>",
      "css": ".s5{height:100%;display:flex;flex-direction:column;justify-content:center;gap:46px} .s5__tag{font-size:18px;font-weight:900;letter-spacing:.16em;color:var(--color-accent)} .s5__title{white-space:pre-line;font-size:92px;font-weight:900;letter-spacing:-0.05em;line-height:1.08;color:var(--color-text-primary)} .s5__muted{color:var(--color-text-secondary);font-weight:800} .s5__date{display:flex;align-items:center;gap:22px;font-size:108px;font-weight:900;letter-spacing:-0.06em;color:var(--color-text-primary)} .s5__dash{display:inline-block;flex:1;height:10px;background:var(--color-accent);max-width:280px} .s5__note{font-size:32px;font-weight:600;color:var(--color-text-secondary);max-width:920px;line-height:1.55;word-break:keep-all}"
