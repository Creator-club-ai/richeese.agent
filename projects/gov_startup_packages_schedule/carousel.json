    {
      "theme": "light",
      "chrome": "full",
      "footer": "minimal",
      "html": "<div class=\"s7\">\n  <div class=\"s7__head\">\n    <div class=\"s7__kicker\">ONE-PAGE</div>\n    <div class=\"s7__title\">2026 접수기간\n요약표</div>\n  </div>\n\n  <div class=\"s7__table\">\n    <div class=\"s7__row s7__row--head\">\n      <div>프로그램</div>\n      <div>접수기간</div>\n    </div>\n    <div class=\"s7__row\">\n      <div class=\"s7__name\">예비 (수정)</div>\n      <div class=\"s7__date\">03.06 ~ 03.24</div>\n    </div>\n    <div class=\"s7__row\">\n      <div class=\"s7__name\">초기 (일반)</div>\n      <div class=\"s7__date\">01.23 ~ 02.13</div>\n    </div>\n    <div class=\"s7__row\">\n      <div class=\"s7__name\">도약 (일반)</div>\n      <div class=\"s7__date\">01.23 ~ 02.13</div>\n    </div>\n  </div>\n\n  <div class=\"s7__note\"><span class=\"s7__dot\"></span> 참고: 도약(딥테크 특화형) 01.06 ~ 01.27</div>\n</div>",
      "css": ".s7{height:100%;display:flex;flex-direction:column;justify-content:center;gap:38px} .s7__kicker{font-size:18px;font-weight:900;letter-spacing:.18em;color:var(--color-accent)} .s7__title{white-space:pre-line;font-size:92px;font-weight:900;letter-spacing:-0.05em;line-height:1.06;color:var(--color-text-primary)} .s7__table{display:flex;flex-direction:column;border:2px solid var(--color-text-primary);border-radius:18px;overflow:hidden} .s7__row{display:grid;grid-template-columns:1fr 1fr;gap:0;align-items:center;padding:30px 34px;border-top:1px solid rgba(26,26,26,.18)} .s7__row--head{border-top:none;background:rgba(26,26,26,.06);font-size:18px;font-weight:900;letter-spacing:.12em;text-transform:uppercase;color:var(--color-text-secondary)} .s7__name{font-size:40px;font-weight:900;letter-spacing:-0.03em;color:var(--color-text-primary)} .s7__date{font-size:40px;font-weight:900;letter-spacing:-0.03em;color:var(--color-text-primary)} .s7__note{display:flex;align-items:center;gap:16px;font-size:30px;font-weight:650;color:var(--color-text-secondary);word-break:keep-all} .s7__dot{width:10px;height:10px;border-radius:50%;background:var(--color-accent);flex-shrink:0}"
    },

    {
      "theme": "dark",
      "chrome": "none",
      "footer": "none",
      "html": "<div class=\"s8\">\n  <div class=\"s8__inner\">\n    <div class=\"s8__kicker\">PRACTICAL</div>\n    <div class=\"s8__title\">접수 전에\n이것만은</div>\n\n    <div class=\"s8__list\">\n      <div class=\"s8__item\"><span class=\"s8__n\">01</span><span class=\"s8__t\">마감 24시간 전에 제출 (막판 트래픽 리스크)</span></div>\n      <div class=\"s8__item\"><span class=\"s8__n\">02</span><span class=\"s8__t\">공고 첨부파일/제출서류 리스트부터 고정</span></div>\n      <div class=\"s8__item\"><span class=\"s8__n\">03</span><span class=\"s8__t\">K-Startup / 기업마당 즐겨찾기</span></div>\n    </div>\n\n    <div class=\"s8__cta\">저장해두면, 시즌에 바로 꺼내 씁니다.</div>\n  </div>\n</div>",
      "css": ".s8{position:absolute;inset:0;background:var(--color-bg-dark);color:#fff} .s8__inner{height:100%;display:flex;flex-direction:column;justify-content:center;padding:0 88px;gap:42px} .s8__kicker{font-size:18px;font-weight:900;letter-spacing:.18em;color:rgba(255,81,0,.95)} .s8__title{white-space:pre-line;font-size:108px;font-weight:900;letter-spacing:-0.06em;line-height:1.02} .s8__list{display:flex;flex-direction:column;gap:18px;margin-top:8px} .s8__item{display:flex;gap:22px;align-items:flex-start;padding:26px 28px;border:1px solid rgba(255,255,255,.12);border-radius:18px;background:rgba(255,255,255,.04)} .s8__n{width:54px;height:54px;border-radius:14px;background:rgba(255,81,0,.16);border:1px solid rgba(255,81,0,.30);display:flex;align-items:center;justify-content:center;font-size:18px;font-weight:900;letter-spacing:.08em;color:rgba(255,81,0,.98);flex-shrink:0;margin-top:2px} .s8__t{font-size:34px;font-weight:700;line-height:1.35;color:rgba(255,255,255,.88);word-break:keep-all} .s8__cta{margin-top:8px;font-size:30px;font-weight:700;color:rgba(255,255,255,.65)}"
