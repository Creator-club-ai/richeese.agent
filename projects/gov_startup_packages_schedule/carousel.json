      "css": ".s9{height:100%;display:flex;flex-direction:column;justify-content:center;gap:36px} .s9__hero{white-space:pre-line;font-size:104px;font-weight:950;letter-spacing:-0.07em;line-height:1.02;color:var(--color-text-primary)} .s9__box{background:var(--color-box-bg-light);border:1px solid var(--color-border-light);border-left:10px solid var(--color-accent);border-radius:20px;padding:30px 34px;display:flex;flex-direction:column;gap:14px} .s9__label{font-size:18px;font-weight:900;letter-spacing:.16em;text-transform:uppercase;color:var(--color-text-secondary)} .s9__src{white-space:pre-line;font-size:30px;font-weight:750;line-height:1.4;color:var(--color-text-primary)} .s9__foot{font-size:26px;font-weight:650;color:var(--color-text-secondary)}"
